# =============================================================
# Travel AI — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — NEVER commit real secrets.
# =============================================================

# ── Supabase (required) ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Google AI / Gemini (required) ────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Google Places / Maps (required for place research) ───────
GOOGLE_PLACES_API_KEY=your-google-places-api-key
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=your-google-maps-embed-key

# ── Amadeus (optional — for real flight/hotel search) ────────
AMADEUS_CLIENT_ID=your-amadeus-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-client-secret

# ── Mapbox (optional — for map visuals) ──────────────────────
MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# ── Resend (optional — for email sending) ────────────────────
RESEND_API_KEY=your-resend-api-key

# ── ElevenLabs (optional — for text-to-speech) ───────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key
